NODE_ENV=production
DOMAIN=vpn.example.com

POSTGRES_DB=lumavpn
POSTGRES_USER=lumavpn
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://lumavpn:change-me@postgres:5432/lumavpn?schema=public
REDIS_URL=redis://redis:6379

JWT_SECRET=change-me-64-bytes
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

BACKEND_PORT=3001
FRONTEND_PORT=3000
BACKEND_PUBLIC_URL=https://vpn.example.com/api
FRONTEND_PUBLIC_URL=https://vpn.example.com
NEXT_PUBLIC_API_URL=https://vpn.example.com/api

TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_BOT_USERNAME=lumastackvpn_bot
TELEGRAM_ADMIN_IDS=274685406
TELEGRAM_SUPPORT_URL=https://t.me/support

YOOKASSA_SHOP_ID=replace-me
YOOKASSA_SECRET_KEY=replace-me
YOOKASSA_RETURN_URL=https://vpn.example.com/account
YOOKASSA_WEBHOOK_SECRET=optional-shared-secret

XRAY_API_HOST=xray
XRAY_API_PORT=10085
XRAY_SERVER_NAME=vpn.example.com
XRAY_PUBLIC_HOST=vpn.example.com
XRAY_PUBLIC_PORT=443
XRAY_REALITY_PUBLIC_KEY=replace-me
XRAY_REALITY_SHORT_ID=replace-me

AMNEZIA_SERVER_PUBLIC_KEY=replace-me
AMNEZIA_ENDPOINT=vpn.example.com:51820
AMNEZIA_DNS=1.1.1.1
AMNEZIA_ALLOWED_IPS=0.0.0.0/0,::/0
AMNEZIA_INTERFACE=awg0

MTPROTO_HOST=vpn.example.com
MTPROTO_PORT=443
MTPROTO_SECRET=replace-with-32-hex-secret
